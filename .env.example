# Helius API configuration
HELIUS_API_KEY=your_helius_api_key
HELIUS_RPC=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key

# Wallet configuration
WALLET_PRIVATE_KEY=your_wallet_private_key
WALLET_ADDRESS=your_wallet_address

# Birdeye API for token analysis
BIRDEYE_API_KEY=your_birdeye_api_key

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Trading configuration
BUY_AMOUNT_SOL=0.1
MAX_SLIPPAGE_BPS=500
TAKE_PROFIT_PCT=30
STOP_LOSS_PCT=15
PRIORITY_FEE_LAMPORTS=10000
MAX_POSITION_SOL=1.0
MAX_OPEN_POSITIONS=5

# RPC endpoints
QUICKNODE_RPC=https://your-quicknode-endpoint.quiknode.pro/your-key
FALLBACK_RPC=https://api.mainnet-beta.solana.com
